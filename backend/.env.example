# Copia este archivo como ".env" y completa los valores reales.
# El archivo .env NO se sube a git (está en .gitignore).

# Conexión a la base de datos PostgreSQL de Supabase.
# En Supabase: botón "Connect" (arriba) > pestaña "ORMs" > Prisma.
# Ahí aparecen ambas cadenas listas para copiar.

# Conexión con pooler (puerto 6543) - uso normal de la app
DATABASE_URL="postgresql://usuario:contrasena@host:6543/postgres?pgbouncer=true"
# Conexión directa (puerto 5432) - solo para migraciones
DIRECT_URL="postgresql://usuario:contrasena@host:5432/postgres"

# Clave secreta para firmar los tokens de sesión (login). Poné un texto largo y aleatorio.
JWT_SECRET="cambia-esto-por-un-texto-largo-y-secreto"

# Puerto donde corre el backend
PORT=4000

# Usuario administrador inicial (usado por "npm run seed")
ADMIN_NOMBRE="Nombre del administrador"
ADMIN_EMAIL="admin@ejemplo.com"
ADMIN_PASSWORD="una-contrasena-segura"
